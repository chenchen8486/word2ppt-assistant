# 2. 图片与多媒体文件
# =========================
*.png
*.jpg
*.jpeg
*.gif
*.bmp
*.svg
*.webp
# 忽略代码临时提取出来的图片文件夹
temp_images/

# =========================
# 3. 敏感信息与本地配置 (⚠️绝对不能上传)
# =========================
API_KEY.txt
config.json
.env

# =========================
# 4. 项目运行时的临时文件与下载的二进制包
# =========================
# Marp CLI 相关的独立程序和压缩包
bin/
marp.exe
marp.zip
# 渲染过程中的临时 Markdown
temp_slides.md
temp.md
# 日志文件
logs/
*.log

# =========================
# 5. Python 基础与环境 (常规忽略)
# =========================
__pycache__/
*.py[cod]
*$py.class
# 虚拟环境 (比如你提到的 conda 激活的 env)
venv/
env/
.venv/

# =========================
# 6. 操作系统与开发工具缓存
# =========================
.DS_Store
Thumbs.db
.vscode/
.idea/
.cursor/

